# Strategy
STRATEGY_MODE=original
TRADE_SYMBOL=SPY
LOOKBACK_PERIOD=400
STATE_DIR=/app/state

# Run mode
# daily = 常驻容器，每天指定 UTC 时间跑一次
# once  = 启动后只跑一次然后退出
RUN_MODE=daily
RUN_ON_START=true
# 美股收盘后建议设置为 22:30 UTC 左右（夏令时约对应美东 18:30）
RUN_TIME_UTC=22:30

# yfinance retry / rate-limit handling
YF_MAX_RETRIES=5
YF_RETRY_BASE_SECONDS=30
YF_BATCH_DELAY_SECONDS=2

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true
EMAIL_FROM=bot@example.com
EMAIL_TO=recipient@example.com
EMAIL_SUBJECT_PREFIX=[VIX-Strategy]
